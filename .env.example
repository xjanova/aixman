# ===========================================
# AIXMAN - AI Generation Platform
# ===========================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_XMAN_URL=https://xman4289.com
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# Database (shared with xmanstudio)
DATABASE_URL="mysql://user:password@localhost:3306/xmanstudio"

# Encryption key for API keys in database (must be at least 32 characters)
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Webhook secret shared with xmanstudio for credit purchases
XMAN_WEBHOOK_SECRET=your-webhook-secret-here

# Secret for the cron endpoint that resets account-pool usage counters
# Schedule daily: curl -H "Authorization: Bearer $CRON_SECRET" <app>/api/cron/reset-counters
CRON_SECRET=your-cron-secret-here

# ===========================================
# Cloudflare R2 storage (durable storage for generated images/videos)
# Provider URLs expire, so generated assets are persisted to R2. Leave blank to
# disable (assets then keep their original provider URL / base64 — no durability).
# Create an R2 bucket + an R2 API token (Object Read & Write) in the Cloudflare
# dashboard, then enable Public Access (r2.dev) or attach a custom domain.
# ===========================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=aixman-generations
# Public base URL of the bucket (no trailing slash), e.g. https://pub-xxxx.r2.dev
R2_PUBLIC_URL=

# ===========================================
# AI Provider API Keys (configured via admin panel)
# These are fallbacks if not set in database
# ===========================================

# BytePlus (Seedream / Seedance)
BYTEPLUS_API_KEY=
BYTEPLUS_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# OpenAI (GPT Image / DALL-E / Sora)
OPENAI_API_KEY=

# Replicate
REPLICATE_API_TOKEN=

# fal.ai
FAL_API_KEY=

# Stability AI
STABILITY_API_KEY=

# Runway ML
RUNWAY_API_SECRET=

# Kling AI
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# Luma AI
LUMA_API_KEY=

# Leonardo.ai
LEONARDO_API_KEY=
